{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "番茄钟",
  "version": "0.1.0",
  "identifier": "com.pomodoro.tomato",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "番茄钟",
        "label": "main",
        "width": 280,
        "height": 260,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
